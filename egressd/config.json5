{
  // Proxy chain -- add as many hops as you need.
  // This is the only required field; everything else uses safe defaults.
  proxies: [
    "http://proxy1:3128",
    "http://proxy2:3128",
  ],

  // Optional overrides for the chain behavior.
  // Remove or leave this section out entirely for the simplest setup; the values shown here are examples, not defaults.
  chain: {
    canary_target: "exitserver:9999",
    allowed_ports: [80, 443, 9999],
  },

  logging: {
    chain_visual: true,
  },

  supervisor: {
    // Compose clients need to read /health across the private worknet.
    health_bind: "0.0.0.0",
  },
}
