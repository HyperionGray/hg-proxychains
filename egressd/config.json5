{
  listener: {
    bind: "0.0.0.0",
    port: 15001,
    mode: "explicit",
  },

  dns: {
    launch_funkydns: false,
    mode: "external",
    resolver_host: "funky",
    resolver_port: 53,
    doh_upstream: "https://cloudflare-dns.com/dns-query",
  },

  chain: {
    name: "default",
    hops: [
      { url: "http://proxy1:3128" },
      { url: "http://proxy2:3128" },
    ],
    canary_target: "example.com:443",
    allowed_ports: [80, 443, 9999],
    fail_closed: true,
    connect_timeout_ms: 5000,
    idle_timeout_ms: 60000,
  },

  logging: {
    level: "INFO",
    json: true,
  },

  supervisor: {
    pproxy_bin: "pproxy",
    funkydns_bin: "funkydns",
    health_bind: "0.0.0.0",
    health_port: 9191,
    hop_check_interval_s: 5,
    block_start_until_hops_healthy: true,
    min_healthy_hops: 2,
  },
}
