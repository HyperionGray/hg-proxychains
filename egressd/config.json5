{
  // Proxy chain -- add as many hops as you need.
  // This is the only required field; everything else uses safe defaults.
  proxies: [
    "http://proxy1:3128",
    "http://proxy2:3128",
  ],
  // Compact shorthand also works:
  // chain: { hops: "http://proxy1:3128__http://proxy2:3128" },

  // Optional overrides (all of these are already set to their default values).
  // Remove or leave this section out entirely for the simplest setup.
  chain: {
    canary_target: "exitserver:9999",
    allowed_ports: [80, 443, 9999],
  },
}
