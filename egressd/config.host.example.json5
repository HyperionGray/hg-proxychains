{
  listener: {
    bind: "172.18.0.1",
    port: 15001,
  },

  dns: {
    launch_funkydns: true,
    port: 53,
    doh_upstreams: [
      "https://your-doh.example/dns-query",
      "https://backup-doh.example/dns-query",
    ],
  },

  chain: {
    name: "default",
    hops: [
      { url: "http://user1:pass1@proxy1.internal:3128" },
      { url: "http://user2:pass2@proxy2.internal:3128" },
    ],
    canary_target: "example.com:443",
    allowed_ports: [80, 443],
    fail_closed: true,
    connect_timeout_ms: 5000,
    idle_timeout_ms: 60000,
  },

  logging: {
    level: "INFO",
    json: true,
    // Set chain_visual to true for a terminal-friendly proxychains-style
    // display showing each hop and its health status.
    chain_visual: false,
    // Optional: emit a periodic snapshot even when hop health does not change.
    // Set to 0 to print only when hop status changes.
    chain_visual_interval_s: 0,
  },

  supervisor: {
    pproxy_bin: "/usr/local/bin/pproxy",
    funkydns_bin: "/usr/local/bin/funkydns",
    health_bind: "127.0.0.1",
    health_port: 9191,
    hop_check_interval_s: 5,
    require_all_hops_healthy: true,
    ready_grace_period_s: 20,
    max_hop_status_age_s: 30,
  },
}
