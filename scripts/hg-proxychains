#!/usr/bin/env bash
# Host-side helper: run workloads through the compose smoke stack (egressd chain).
# Prereq: podman-compose (override with HG_PROXYCHAINS_COMPOSE or COMPOSE).

set -euo pipefail

COMPOSE_CMD="${HG_PROXYCHAINS_COMPOSE:-${COMPOSE:-podman-compose}}"

usage() {
  cat <<'EOF'
hg-proxychains -- smoke harness helper

  Stack (from repo root): DNS/DoH via funky, TCP via egressd CONNECT chain.

Commands:
  daemon          Start stack in background (compose up -d --build).
  stop            Stop stack and remove volumes (compose down -v).
  run [--] CMD..  Run CMD in the client image on egressnet (HTTP(S)_PROXY=egressd).
                  DNS resolver is set to funky (DoH-capable resolver in the stack).
  status          Print compose ps one-liner.
  logs [SERVICE]  Follow logs (default: egressd; optional extra compose args).

Environment:
  HG_PROXYCHAINS_COMPOSE   Compose command (default: podman-compose or $COMPOSE).

Examples (from clone root, after ./scripts/hg-proxychains daemon):
  ./scripts/hg-proxychains run -- curl -fsS http://exitserver:9999/
  ./scripts/hg-proxychains run -- python3 -c "import urllib.request; print(urllib.request.urlopen('http://exitserver:9999/').read())"
EOF
}

find_repo_root() {
  local d
  d=$(pwd -P)
  while [[ "$d" != "/" ]]; do
    if [[ -f "$d/docker-compose.yml" ]] && grep -qE '^[[:space:]]+egressd:' "$d/docker-compose.yml" 2>/dev/null; then
      printf '%s\n' "$d"
      return 0
    fi
    d=$(dirname "$d")
  done
  echo "hg-proxychains: could not find docker-compose.yml with an egressd service (run from repo root or a subdirectory)." >&2
  return 1
}

cd_root() {
  local root
  root=$(find_repo_root) || exit 1
  cd "$root"
}

run_in_client() {
  if [[ $# -lt 1 ]]; then
    echo "hg-proxychains: missing command after 'run' (try: hg-proxychains run -- curl ...)" >&2
    exit 2
  fi
  # HTTP CONNECT proxy; apps must honor these (curl, pip, many CLIs do).
  export HTTP_PROXY="${HTTP_PROXY:-http://egressd:15001}"
  export HTTPS_PROXY="${HTTPS_PROXY:-http://egressd:15001}"
  export ALL_PROXY="${ALL_PROXY:-http://egressd:15001}"
  export NO_PROXY="${NO_PROXY:-localhost,127.0.0.1,::1,egressd}"
  export FTP_PROXY="${FTP_PROXY:-http://egressd:15001}"
  export DOH_URL="${DOH_URL:-https://funky/dns-query}"
  export DNS_SERVER="${DNS_SERVER:-funky}"
  exec $COMPOSE_CMD run --rm -T --no-deps \
    --dns funky \
    -e HTTP_PROXY -e HTTPS_PROXY -e ALL_PROXY -e NO_PROXY -e FTP_PROXY \
    -e DOH_URL -e DNS_SERVER \
    client "$@"
}

case "${1:-}" in
  daemon)
    cd_root
    shift
    exec $COMPOSE_CMD up -d --build "$@"
    ;;
  stop)
    cd_root
    shift
    exec $COMPOSE_CMD down -v "$@"
    ;;
  run)
    cd_root
    shift
    if [[ "${1:-}" == "--" ]]; then
      shift
    fi
    run_in_client "$@"
    ;;
  status)
    cd_root
    shift
    exec $COMPOSE_CMD ps "$@"
    ;;
  logs)
    cd_root
    shift
    svc="egressd"
    if [[ $# -gt 0 && "${1:-}" != -* ]]; then
      svc="$1"
      shift
    fi
    exec $COMPOSE_CMD logs -f --tail=200 "$svc" "$@"
    ;;
  -h|--help|help|"")
    usage
    [[ -n "${1:-}" ]] || exit 0
    exit 0
    ;;
  *)
    echo "hg-proxychains: unknown command: $1" >&2
    usage >&2
    exit 2
    ;;
esac
